# Supabase (обязательно)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Avito OAuth (для синхронизации и календаря, а также Messenger API)
VITE_AVITO_CLIENT_ID=your_avito_client_id
VITE_AVITO_REDIRECT_URI=https://app.roomi.pro/auth/avito-callback

# Bootstrap первого админа: при первом входе пользователя с этим email ему выдаётся role=admin
# VITE_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Telegram OTP: для доставки кода входа в Telegram задайте секрет в Supabase:
# Project Settings → Edge Functions → Secrets → TELEGRAM_BOT_TOKEN = <токен от @BotFather>
# Или: supabase secrets set TELEGRAM_BOT_TOKEN=your_bot_token

# Имя бота в Telegram для подсказки на странице входа (опционально)
# VITE_TELEGRAM_BOT_USERNAME=RoomiProBot

